# Server Configuration
PORT=5000

# Database (MongoDB Atlas M0 Sandbox / Local MongoDB)
MONGODB_URI=mongodb://localhost:27017/verdict

# Edge Cache / Rate Limiter (Upstash Serverless Redis REST API)
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Gemini LLM API (Google AI Studio Key)
GEMINI_API_KEY=your_gemini_api_key
